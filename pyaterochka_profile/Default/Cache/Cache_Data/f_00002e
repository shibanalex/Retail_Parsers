и ценниками “высокая оценка”. Если вы увидите такой ценник, то можете быть уверенными в качестве товара, ведь наши покупатели отдали за него свои голоса."},{question:"Почему я не могу оценить купленные товары?",answer:"<p>Если в списке для оценки нет купленных вами товаров, возможно вы:</p><ul><li>Не использовали карту лояльности при покупке.</li><li>Делали покупки больше 30 дней назад.</li><li>Уже оценивали этот товар за последние 30 дней.</li></ul><p>Если ни одна из причин не подходит, напишите в поддержку — все способы есть в разделе \xabСвязаться\xbb.</p>"},{question:`Какой срок действия ${_.H[2]} за оценку товара?`,answer:`3 месяца с момента начисления ${_.H[2]}`}]}]});var H=a(78519),I=a.n(H);let M=()=>{let{questions:e}=R(),t=e=>{v("click",{object:"accordion",subject:"user",accordion_name:"question",content_title:e})};return(0,i.jsxs)(o.xu,{as:"article",className:I().wrapper,children:[(0,i.jsx)(o.xu,{as:"header",className:I().header,children:(0,i.jsx)(m,{as:"h2",variant:{base:"mobile-h3-black",md:"h2-black"},className:I().title,children:"Остались вопросы?"})}),e.map(a=>(0,i.jsxs)(o.xu,{className:I().category,as:"section",children:[e.length>1&&(0,i.jsx)(o.xu,{className:I().categoryTitle,children:(0,i.jsx)(m,{as:"h3",variant:{base:"mobile-medium-black",md:"h4-black"},children:a.category})}),(0,i.jsx)(C,{className:I().questions,allowToggle:!0,children:a.items.map(e=>(0,i.jsxs)(P,{className:I().item,children:[(0,i.jsxs)(w,{className:I().itemButton,onClick:()=>t(e.answer),children:[(0,i.jsx)(m,{variant:{base:"mobile-description-regular",md:"medium-regular"},children:e.question}),(0,i.jsx)(T,{className:I().itemIcon})]}),(0,i.jsx)(S,{children:(0,i.jsx)(m,{className:I().answer,as:"div",variant:{base:"mobile-description-regular",md:"description-regular"},dangerouslySetInnerHTML:{__html:e.answer}})})]},e.question))})]},a.category))]})};var L=a(30350),$=a(81550),A=a(9165),F=a(59572),E=a(25578),q=a(85244),V=a(4028),D=a(31053),[z,O,W,U]=(0,$.n)(),[X,G]=(0,A.k)({name:"TabsCo