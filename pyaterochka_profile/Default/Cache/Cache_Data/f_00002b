ами в магазинах. Удобно, что баллами можно оплачивать в двух сетях.<br /><br />Проверяю несколько дней в неделю, для меня это как мини тренажёрный зал. Сотрудники обычно быстро понимают, что я тайный покупатель, но реагируют доброжелательно, потому что я им помогаю делать свою работу лучше."}]}),P=()=>{let[e,r]=(0,n.useState)(null),[s,a]=(0,n.useState)(!0),[t,l]=(0,n.useState)(!1),[o,i]=(0,n.useState)(3),c=e=>{e.matches?i(1.2):i(3)};return(0,n.useEffect)(()=>{let e=window.matchMedia("(max-width: 768px)");return e.addEventListener("change",c),c(e),()=>{e.removeEventListener("change",c)}},[]),{isEnd:t,swiper:e,isBegin:s,sliderPerView:o,handleSetSwiper:e=>{r(e)},handleSlideChange:e=>{a(e.isBeginning),l(e.isEnd)}}};var E=s(79259),H=s(6611);let O=e=>{let{swiper:r,isEnd:s,className:l,ariaControls:o}=e;return(0,a.jsx)(t.xu,{as:"button",className:(0,c.Z)(H.wrapper,l),onClick:()=>r?.navigation?.nextEl?.click(),"aria-label":"Следующие истории","aria-controls":o,children:(0,a.jsx)(E.X,{className:(0,c.Z)({[H.chevronSvg]:s})})})};var L=s(60516);let Z=e=>{let{swiper:r,isBegin:s,className:l,ariaControls:o}=e;return(0,a.jsx)(t.xu,{as:"button",className:(0,c.Z)(L.wrapper,l),onClick:()=>r?.navigation?.prevEl?.click(),"aria-label":"Предыдущие истории","aria-controls":o,children:(0,a.jsx)(E.X,{className:(0,c.Z)({[L.chevronSvg]:s})})})};var $=s(48603),z=s(29477);let M=e=>{let{title:r,subTitle:s,hint:l,description:o,image:i,color:n}=e;return(0,a.jsxs)(t.xu,{as:"article",className:z.wrapper,children:[(0,a.jsxs)(t.xu,{className:z.header,children:[(0,a.jsxs)(t.xu,{children:[(0,a.jsx)(_.x,{as:"h3",variant:{base:"ms-mobile-description-semibold",md:"ms-medium-semibold"},children:r}),s&&(0,a.jsx)(_.x,{as:"h4",variant:{base:"ms-mobile-description-semibold",md:"ms-medium-semibold"},children:s}),(0,a.jsx)(_.x,{className:z.hint,variant:{base:"ms-mobile-caption-regular",md:"ms-caption-2-regula"},style:{"--hint-color":n||"#4D88FF66"},children:l})]}),(0,a.jsx)(x,{width:191,height:191,className:z.image